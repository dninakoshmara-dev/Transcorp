generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TripStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TripShipmentStatus {
  ALLOCATED
  LOADED
  DELIVERED
  CANCELLED
}

model Warehouse {
  id        String   @id @default(cuid())
  code      String
  name      String
  country   String
  address   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  shipments      Shipment[]
  trucksHome     Truck[]    @relation("TruckHomeWarehouse")
  tripsStartHere Trip[]     @relation("TripStartWarehouse")
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  vat       String?
  address   String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  shipments Shipment[]
  trips     Trip[]
}

model Shipment {
  id           String   @id @default(cuid())
  refNo        String
  description  String?
  palletsTotal Int
  weightKg     Int?
  notes        String?
  statusCalc   String?

  customerId  String
  warehouseId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  customer  Customer  @relation(fields: [customerId], references: [id])
  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  tripShipments TripShipment[]
}

model Truck {
  id              String   @id @default(cuid())
  plate           String
  capacityPallet  Int
  capacityKg      Int
  homeWarehouseId String
  isActive        Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  homeWarehouse Warehouse @relation("TruckHomeWarehouse", fields: [homeWarehouseId], references: [id])
  trips          Trip[]
}

model Driver {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  trips Trip[]
}

model Trip {
  id               String     @id @default(cuid())
  status           TripStatus @default(PLANNED)

  plannedStartAt   DateTime?
  plannedEndAt     DateTime?

  revenueAmount    Int?
  revenueCurrency  String?

  truckId          String
  driverId         String?
  startWarehouseId String
  customerId       String?

  startedAt        DateTime?
  completedAt      DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  truck          Truck     @relation(fields: [truckId], references: [id])
  driver         Driver?   @relation(fields: [driverId], references: [id])
  startWarehouse Warehouse @relation("TripStartWarehouse", fields: [startWarehouseId], references: [id])
  customer       Customer? @relation(fields: [customerId], references: [id])

  shipments TripShipment[]
  expenses  TripExpense[]
}

model DropStop {
  id        String   @id @default(cuid())
  name      String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tripShipments TripShipment[]
}

model TripShipment {
  id               String             @id @default(cuid())

  tripId           String
  shipmentId       String

  palletsAllocated Int
  palletsLoaded    Int?
  palletsDelivered Int?

  dropStopId       String?
  status           TripShipmentStatus?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // relations
  trip     Trip     @relation(fields: [tripId], references: [id])
  shipment Shipment @relation(fields: [shipmentId], references: [id])
  dropStop DropStop? @relation(fields: [dropStopId], references: [id])

  @@unique([tripId, shipmentId])
  @@index([tripId])
  @@index([shipmentId])
}

enum ExpenseType {
  FUEL
  TOLL
  FERRY
  PARKING
  OTHER
}

model TripExpense {
  id          String      @id @default(cuid())
  tripId      String
  type        ExpenseType
  amount      Float
  currency    String      @default("EUR")
  note        String?
  receiptUrl  String?
  createdAt   DateTime    @default(now())
  createdById String?
  updatedAt   DateTime    @default(now()) @updatedAt

  // relations
  trip Trip @relation(fields: [tripId], references: [id])

  @@index([tripId])
  @@map("Expense")
}

